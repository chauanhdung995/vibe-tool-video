{
  "name": "vibe-tool-video",
  "version": "1.0.0",
  "description": "NodeJS modular video generation app with resumable pipeline",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "prepare:vendor": "node scripts/prepare-vendor.js",
    "dist:mac": "npm run prepare:vendor && electron-builder --mac dmg --arm64",
    "dist:win": "npm run prepare:vendor && electron-builder --win nsis --x64 --publish never"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "hyperframes": "^0.4.43",
    "multer": "^1.4.5-lts.1",
    "puppeteer-core": "^24.42.0"
  },
  "devDependencies": {
    "@puppeteer/browsers": "^2.13.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.vibetool.video",
    "productName": "Vibe Tool Video",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "scripts/prepare-vendor.js",
      "server.js",
      "src/**/*",
      "public/**/*",
      "vendor/chrome/**/*",
      "package.json",
      "!node_modules/ffprobe-static/bin/linux/**/*",
      "!node_modules/ffprobe-static/bin/darwin/x64/**/*",
      "!projects/**/*",
      "!storage/**/*",
      "!tmp/**/*",
      "!dist/**/*",
      "!*.dmg"
    ],
    "mac": {
      "category": "public.app-category.video",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vibe Tool Video"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
